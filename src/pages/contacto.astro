---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contacto — Mantilhue Alimentos"
  description="Contáctanos para cotizar productos o resolver dudas. WhatsApp, email, teléfono."
>
  <section class="max-w-7xl mx-auto px-4 py-8 md:py-12">
    <h1 class="font-heading font-bold text-3xl md:text-4xl mb-2">Hablemos de tu negocio</h1>
    <p class="text-base-muted mb-8">Cuéntanos qué necesitas. Te respondemos rápido, sin compromiso y sin letra chica.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12">
      <!-- Formulario -->
      <div>
        <h2 class="font-heading font-bold text-xl mb-4">Envíanos un mensaje</h2>
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-4">
          <div>
            <label for="nombre" class="block text-sm font-medium mb-1">Nombre *</label>
            <input type="text" id="nombre" name="nombre" required class="w-full px-4 py-2 border border-base-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-marques" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-1">Correo electrónico *</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-base-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-marques" />
          </div>
          <div>
            <label for="telefono" class="block text-sm font-medium mb-1">Teléfono</label>
            <input type="tel" id="telefono" name="telefono" class="w-full px-4 py-2 border border-base-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-marques" />
          </div>
          <div>
            <label for="mensaje" class="block text-sm font-medium mb-1">Consulta *</label>
            <textarea id="mensaje" name="mensaje" rows="4" required class="w-full px-4 py-2 border border-base-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-marques resize-y"></textarea>
          </div>
          <!-- Honeypot anti-spam -->
          <input type="text" name="_gotcha" class="hidden" />
          <button type="submit" class="bg-marques text-white px-6 py-3 rounded-lg font-semibold hover:brightness-110 transition w-full">
            Enviar
          </button>
        </form>
      </div>

      <!-- Info de contacto -->
      <div class="space-y-6">
        <div>
          <h2 class="font-heading font-bold text-xl mb-4">Información de contacto</h2>
          <ul class="space-y-3 text-sm text-base-muted">
            <li class="flex items-start gap-3">
              <span class="font-semibold text-base-text min-w-[80px]">Dirección:</span>
              Población Larraín Lote 10 S/N, Pabellón Melipilla, Chile
            </li>
            <li class="flex items-start gap-3">
              <span class="font-semibold text-base-text min-w-[80px]">Teléfono:</span>
              <a href="tel:+56226015144" class="hover:text-marques">+562 260 15 144</a>
            </li>
            <li class="flex items-start gap-3">
              <span class="font-semibold text-base-text min-w-[80px]">Celular:</span>
              <a href="tel:+56988074192" class="hover:text-marques">+569 8807 4192</a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="font-heading font-semibold text-base mb-2">Correos por área</h3>
          <ul class="space-y-1 text-sm text-base-muted">
            <li><a href="mailto:contacto@mantilhuealimentos.cl" class="hover:text-marques">contacto@mantilhuealimentos.cl</a> — General</li>
            <li><a href="mailto:ventas@mantilhuealimentos.cl" class="hover:text-marques">ventas@mantilhuealimentos.cl</a> — Ventas</li>
            <li><a href="mailto:despachos@mantilhuealimentos.cl" class="hover:text-marques">despachos@mantilhuealimentos.cl</a> — Despachos</li>
            <li><a href="mailto:ccalidad@mantilhuealimentos.cl" class="hover:text-marques">ccalidad@mantilhuealimentos.cl</a> — Calidad</li>
            <li><a href="mailto:gerencia@mantilhuealimentos.cl" class="hover:text-marques">gerencia@mantilhuealimentos.cl</a> — Gerencia</li>
          </ul>
        </div>

        <a
          href="https://wa.me/56988074192?text=Hola%2C%20me%20interesa%20cotizar%20productos%20de%20Mantilhue%20Alimentos"
          target="_blank"
          rel="noopener"
          class="flex items-center justify-center gap-2 bg-whatsapp text-white px-6 py-3 rounded-lg font-semibold hover:brightness-110 transition"
        >
          Contactar por WhatsApp
        </a>

        <!-- Mapa -->
        <div class="rounded-xl overflow-hidden border border-base-border">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3320.5!2d-71.2!3d-33.68!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sMelipilla!5e0!3m2!1ses!2scl!4v1"
            width="100%"
            height="250"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación Mantilhue Alimentos"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
