---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandCard from '../components/BrandCard.astro';
import { getCollection } from 'astro:content';

const marcas = (await getCollection('marcas'))
  .filter(m => m.data.activa)
  .sort((a, b) => a.data.orden - b.data.orden);
---

<BaseLayout title="Mantilhue Alimentos — Producción y Distribución de Alimentos en Chile">
  <!-- Hero -->
  <section class="bg-base-surface">
    <div class="max-w-7xl mx-auto px-4 py-16 md:py-24 text-center">
      <h1 class="font-heading font-extrabold text-3xl md:text-5xl text-base-text leading-tight mb-4">
        Soluciones en alimentos para negocios que necesitan calidad, continuidad y buen precio
      </h1>
      <p class="text-base-muted text-lg md:text-xl max-w-3xl mx-auto mb-8">
        Producimos y distribuimos productos alimenticios a través de nuestras marcas para cada tipo de cliente
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/catalogo" class="inline-flex items-center justify-center gap-2 bg-marques text-white px-6 py-3 rounded-lg font-semibold hover:brightness-110 transition">
          Ver catálogo
        </a>
        <a href="https://wa.me/56988074192?text=Hola%2C%20me%20interesa%20cotizar%20productos%20de%20Mantilhue%20Alimentos" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 bg-whatsapp text-white px-6 py-3 rounded-lg font-semibold hover:brightness-110 transition">
          Hablar por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Qué hacemos -->
  <section class="max-w-7xl mx-auto px-4 py-12 md:py-16 text-center">
    <h2 class="font-heading font-bold text-2xl md:text-3xl mb-4">¿Qué hacemos?</h2>
    <p class="text-base-muted text-lg max-w-3xl mx-auto">
      Somos una empresa dedicada a la producción y distribución de alimentos, enfocada en entregar soluciones confiables para negocios, distribuidores y comercios.
    </p>
  </section>

  <!-- Nuestras marcas -->
  <section class="bg-base-surface py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading font-bold text-2xl md:text-3xl text-center mb-8">Nuestras Marcas</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {marcas.map((marca) => (
          <BrandCard
            nombre={marca.data.nombre}
            slug={marca.data.slug}
            descripcionCorta={marca.data.descripcionCorta}
            logo={marca.data.logo}
            colorPrimario={marca.data.colorPrimario}
            colorTexto={marca.data.colorTexto}
          />
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/marcas" class="text-marques font-semibold hover:underline">Ver todas las marcas →</a>
      </div>
    </div>
  </section>

  <!-- Para quién trabajamos -->
  <section class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    <h2 class="font-heading font-bold text-2xl md:text-3xl text-center mb-8">¿Para quién trabajamos?</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { icon: '🏪', label: 'Distribuidores' },
        { icon: '🏬', label: 'Minimarkets' },
        { icon: '🍽️', label: 'Restaurantes' },
        { icon: '🛒', label: 'Comercios' },
      ].map((item) => (
        <div class="bg-base-surface rounded-xl p-6">
          <div class="text-4xl mb-3">{item.icon}</div>
          <p class="font-heading font-semibold text-sm">{item.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Diferenciadores -->
  <section class="bg-base-surface py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading font-bold text-2xl md:text-3xl text-center mb-8">¿Por qué Mantilhue?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: 'Abastecimiento constante', desc: 'Stock permanente con despacho desde nuestra bodega de 3.000 m².' },
          { title: 'Variedad de productos', desc: 'Arroz, azúcar, aceites, legumbres, pastas y más en múltiples marcas.' },
          { title: 'Precios competitivos', desc: 'Marcas para cada segmento: volumen, calidad/precio y premium.' },
          { title: 'Relación directa', desc: 'Atención comercial personalizada. Sin intermediarios.' },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 border border-base-border">
            <h3 class="font-heading font-semibold text-base mb-2">{item.title}</h3>
            <p class="text-sm text-base-muted">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="max-w-7xl mx-auto px-4 py-12 md:py-16 text-center">
    <h2 class="font-heading font-bold text-2xl md:text-3xl mb-4">¿Listo para cotizar?</h2>
    <p class="text-base-muted text-lg mb-6">Revisa nuestro catálogo y contáctanos para recibir precios y disponibilidad.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/catalogo" class="inline-flex items-center justify-center bg-marques text-white px-6 py-3 rounded-lg font-semibold hover:brightness-110 transition">
        Ver catálogo completo
      </a>
      <a href="/contacto" class="inline-flex items-center justify-center border-2 border-base-text text-base-text px-6 py-3 rounded-lg font-semibold hover:bg-base-text hover:text-white transition">
        Contactar
      </a>
    </div>
  </section>
</BaseLayout>
