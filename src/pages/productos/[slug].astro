---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const productos = await getCollection('productos');
  return productos
    .filter(p => p.data.activo)
    .map(producto => ({
      params: { slug: producto.data.slug },
      props: { producto },
    }));
}

const { producto } = Astro.props;

const marcas = await getCollection('marcas');
const marca = marcas.find(m => m.data.slug === producto.data.marca);

const brandLabels: Record<string, string> = {
  'el-marques': 'El Marqués',
  'el-monarca': 'El Monarca',
  'maiten': 'Maitén',
  'carbon-el-valle': 'Carbón El Valle',
};

const catLabels: Record<string, string> = {
  aceites: 'Aceites', arroz: 'Arroz', azucar: 'Azúcar',
  legumbres: 'Legumbres', pastas: 'Pastas', enlatados: 'Enlatados', carbon: 'Carbón',
};

const whatsappMsg = encodeURIComponent(`Hola, me interesa cotizar: ${producto.data.nombre} (${producto.data.formato})`);
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={`${producto.data.nombre} — Mantilhue Alimentos`}
  description={producto.data.descripcion || `${producto.data.nombre} - ${producto.data.formato}. ${brandLabels[producto.data.marca]}.`}
>
  <section class="max-w-7xl mx-auto px-4 py-8 md:py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-base-muted mb-6">
      <a href={base} class="hover:text-marques">Inicio</a>
      <span class="mx-1">/</span>
      <a href={`${base}catalogo`} class="hover:text-marques">Catálogo</a>
      <span class="mx-1">/</span>
      <span class="text-base-text">{producto.data.nombre}</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      <!-- Imagen -->
      <div class="bg-base-surface rounded-xl p-8 flex items-center justify-center">
        <img
          src={`${base}${producto.data.imagen.startsWith("/") ? producto.data.imagen.slice(1) : producto.data.imagen}`}
          alt={producto.data.nombre}
          class="max-h-80 w-auto object-contain"
        />
      </div>

      <!-- Info -->
      <div>
        {marca && (
          <a
            href={`${base}marcas/${marca.data.slug}`}
            class="inline-block text-sm font-semibold px-3 py-1 rounded-full mb-3"
            style={`background-color: ${marca.data.colorPrimario}; color: ${marca.data.colorTexto}`}
          >
            {marca.data.nombre}
          </a>
        )}

        <h1 class="font-heading font-bold text-2xl md:text-3xl mb-2">{producto.data.nombre}</h1>

        <div class="flex flex-wrap gap-3 text-sm text-base-muted mb-4">
          <span class="bg-base-surface px-3 py-1 rounded-full">{catLabels[producto.data.categoria]}</span>
          <span class="bg-base-surface px-3 py-1 rounded-full">{producto.data.tipo}</span>
          <span class="bg-base-surface px-3 py-1 rounded-full">{producto.data.formato}</span>
        </div>

        {producto.data.descripcion && (
          <p class="text-base-muted mb-6">{producto.data.descripcion}</p>
        )}

        <div class="space-y-3">
          <a
            href={`https://wa.me/56988074192?text=${whatsappMsg}`}
            target="_blank"
            rel="noopener"
            class="flex items-center justify-center gap-2 bg-whatsapp text-white px-6 py-3 rounded-lg font-semibold hover:brightness-110 transition w-full"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Cotizar por WhatsApp
          </a>
          <a
            href={`${base}contacto`}
            class="flex items-center justify-center border-2 border-base-text text-base-text px-6 py-3 rounded-lg font-semibold hover:bg-base-text hover:text-white transition w-full"
          >
            Solicitar cotización
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
